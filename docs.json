{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Jumper Docs",
  "colors": {
    "primary": "#6D28D9",
    "light": "#C084FC",
    "dark": "#4C1D95"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Product guide",
            "pages": [
              "using-jumper",
              "faq"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/introduction",
              "api-reference/endpoint/quote",
              "api-reference/endpoint/transfer",
              "api-reference/endpoint/status",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Jumper app",
          "href": "https://jumper.exchange",
          "icon": "arrow-up-right"
        },
        {
          "anchor": "Status",
          "href": "https://status.li.fi",
          "icon": "signal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@jumper.exchange"
      },
      {
        "label": "Developers",
        "href": "https://jumper.exchange"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch Jumper",
      "href": "https://jumper.exchange"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/jumper_exchange",
      "github": "https://github.com/lifinance",
      "linkedin": "https://www.linkedin.com/company/lifi/"
    }
  }
}
